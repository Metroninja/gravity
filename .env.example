# Copy to `.env` and fill in the secrets. docker-compose reads this file
# automatically for variable substitution.

# ---- App ------------------------------------------------------------------
NODE_ENV=development
APP_BASE_URL=http://localhost:8090

# 32+ random characters. Used to sign session cookies. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=dev-secret-change-me-please-32chars

# ---- Database -------------------------------------------------------------
# When running through docker-compose this is set on the service itself; you
# only need this for scripts running on the host (e.g. db:studio).
DATABASE_URL=postgres://janneke:janneke_dev@localhost:5442/janneke

# ---- Auth0 ----------------------------------------------------------------
# Create a "Regular Web Application" in your Auth0 tenant. Enable Username/
# Password and the Google social connection.
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=http://localhost:8090/auth/callback
AUTH0_LOGOUT_RETURN_URL=http://localhost:8090

# ---- Google Cloud Storage -------------------------------------------------
GCS_BUCKET=janneke-media
GCS_PROJECT_ID=janneke-local

# Local only — point at the fake-gcs-server container. Leave UNSET in
# production so the SDK falls back to real GCS with ADC.
GCS_EMULATOR_HOST=http://localhost:4443
